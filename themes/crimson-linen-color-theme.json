{
  "name": "Crimson Linen",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    "editor.background": "#0e0608",
    "editor.foreground": "#e8d8c4",
    "editor.lineHighlightBackground": "#160a0c",
    "editor.selectionBackground": "#561c24",
