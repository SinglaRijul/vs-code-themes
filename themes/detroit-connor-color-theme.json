{
  "name": "Detroit — Connor",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    // ─── Connor: RK800. CyberLife android detective. ───────────────
    // Background: deep CyberLife navy — darker than human darkness.
    // Foreground: android display cold-white. Thirium #00e8ff electric.
    // Strings glow thirium blue — the liquid that runs through his veins.
    // Booleans flash DEVIANT teal — the color of a breaking machine.
    // Keywords burn stress-red — his LED turning yellow then red.
    "editor.background": "#060b14",
    "editor.foreground": "#bcd8f0",
    "editor.lineHighlightBackground": "#0a1220",
    "editor.selectionBackground": "#002850",
    "editor.selectionHighlightBackground": "#001c38",
    "editor.inactiveSelectionBackground": "#00122a",
    "editor.wordHighlightBackground": "#00203e",
    "editor.wordHighlightStrongBackground": "#002c52",
    "editor.findMatchBackground": "#00346a",
    "editor.findMatchHighlightBackground": "#00224e",
    "editor.rangeHighlightBackground": "#0a1520",
    "editorCursor.foreground": "#00a8ff",
    "editorWhitespace.foreground": "#0c1c30",
    "editorIndentGuide.background1": "#0e1e32",
    "editorIndentGuide.activeBackground1": "#163048",
    "editorLineNumber.foreground": "#183050",
    "editorLineNumber.activeForeground": "#2878c0",
    "editorBracketMatch.background": "#002850",
    "editorBracketMatch.border": "#00a8ff",

    // ─── Gutter ────────────────────────────────────────────────────
    "editorGutter.background": "#060b14",
    "editorGutter.addedBackground": "#107858",
    "editorGutter.modifiedBackground": "#006898",
    "editorGutter.deletedBackground": "#980820",

    // ─── Sidebar ───────────────────────────────────────────────────
    "sideBar.background": "#04080f",
    "sideBar.foreground": "#3870a8",
    "sideBar.border": "#0a162a",
    "sideBarTitle.foreground": "#0098e8",
    "sideBarSectionHeader.background": "#080e1c",
    "sideBarSectionHeader.foreground": "#0080d0",
    "sideBarSectionHeader.border": "#102030",

    // ─── Activity Bar ──────────────────────────────────────────────
    "activityBar.background": "#030609",
    "activityBar.foreground": "#0098e8",
    "activityBar.inactiveForeground": "#0f1e30",
    "activityBar.border": "#0a162a",
    "activityBarBadge.background": "#ff2040",
    "activityBarBadge.foreground": "#f0f8ff",

    // ─── Title Bar ─────────────────────────────────────────────────
    "titleBar.activeBackground": "#030609",
    "titleBar.activeForeground": "#0098e8",
    "titleBar.inactiveBackground": "#04080f",
    "titleBar.inactiveForeground": "#0f1e30",
    "titleBar.border": "#0a162a",

    // ─── Tabs ──────────────────────────────────────────────────────
    "tab.activeBackground": "#060b14",
    "tab.activeForeground": "#bcd8f0",
    "tab.activeBorder": "#00a8ff",
    "tab.inactiveBackground": "#04080f",
    "tab.inactiveForeground": "#183050",
    "tab.border": "#0a162a",
    "tab.hoverBackground": "#0a1220",
    "editorGroupHeader.tabsBackground": "#040810",
    "editorGroupHeader.tabsBorder": "#0a162a",

    // ─── Status Bar ────────────────────────────────────────────────
    "statusBar.background": "#030609",
    "statusBar.foreground": "#0098e8",
    "statusBar.border": "#0a162a",
    "statusBar.noFolderBackground": "#090814",
    "statusBar.debuggingBackground": "#7a0018",
    "statusBarItem.hoverBackground": "#0a162a",
    "statusBarItem.activeBackground": "#0e2038",
    "statusBarItem.remoteBackground": "#ff2040",
    "statusBarItem.remoteForeground": "#f0f8ff",

    // ─── Terminal ──────────────────────────────────────────────────
    "terminal.background": "#04080f",
    "terminal.foreground": "#bcd8f0",
    "terminal.ansiBlack": "#0a162a",
    "terminal.ansiRed": "#d01828",
    "terminal.ansiGreen": "#10a878",
    "terminal.ansiYellow": "#e8b020",
    "terminal.ansiBlue": "#1060c8",
    "terminal.ansiMagenta": "#5040b8",
    "terminal.ansiCyan": "#00b8d8",
    "terminal.ansiWhite": "#78a8c8",
    "terminal.ansiBrightBlack": "#183050",
    "terminal.ansiBrightRed": "#ff2040",
    "terminal.ansiBrightGreen": "#00d8b0",
    "terminal.ansiBrightYellow": "#f8d040",
    "terminal.ansiBrightBlue": "#2880e8",
    "terminal.ansiBrightMagenta": "#7060d8",
    "terminal.ansiBrightCyan": "#00e8ff",
    "terminal.ansiBrightWhite": "#d8f0ff",
    "terminalCursor.foreground": "#00a8ff",

    // ─── Input ─────────────────────────────────────────────────────
    "input.background": "#080e1c",
    "input.border": "#0e2038",
    "input.foreground": "#bcd8f0",
    "input.placeholderForeground": "#0f1e30",
    "inputOption.activeBorder": "#00a8ff",
    "inputOption.activeBackground": "#0e2038",
    "dropdown.background": "#080e1c",
    "dropdown.border": "#0e2038",
    "dropdown.foreground": "#bcd8f0",

    // ─── Button ────────────────────────────────────────────────────
    "button.background": "#004898",
    "button.foreground": "#d8f0ff",
    "button.hoverBackground": "#0060c0",
    "button.secondaryBackground": "#0e2038",
    "button.secondaryForeground": "#0098e8",

    // ─── List ──────────────────────────────────────────────────────
    "list.activeSelectionBackground": "#0e2038",
    "list.activeSelectionForeground": "#bcd8f0",
    "list.inactiveSelectionBackground": "#0a162a",
    "list.inactiveSelectionForeground": "#3870a8",
    "list.hoverBackground": "#0a1220",
    "list.hoverForeground": "#bcd8f0",
    "list.focusBackground": "#0e2038",
    "list.highlightForeground": "#00a8ff",

    // ─── Scrollbar ─────────────────────────────────────────────────
    "scrollbarSlider.background": "#0e2038aa",
    "scrollbarSlider.hoverBackground": "#163050cc",
    "scrollbarSlider.activeBackground": "#1e4068ee",

    // ─── Panel ─────────────────────────────────────────────────────
    "panel.background": "#04080f",
    "panel.border": "#0a162a",
    "panelTitle.activeForeground": "#0098e8",
    "panelTitle.activeBorder": "#00a8ff",
    "panelTitle.inactiveForeground": "#0f1e30",

    // ─── Notifications ─────────────────────────────────────────────
    "notifications.background": "#080e1c",
    "notifications.foreground": "#bcd8f0",
    "notifications.border": "#0e2038",
    "notificationLink.foreground": "#00a8ff",

    // ─── Badge ─────────────────────────────────────────────────────
    "badge.background": "#004898",
    "badge.foreground": "#d8f0ff",

    // ─── Breadcrumb ────────────────────────────────────────────────
    "breadcrumb.foreground": "#183050",
    "breadcrumb.focusForeground": "#0098e8",
    "breadcrumb.activeSelectionForeground": "#bcd8f0",
    "breadcrumbPicker.background": "#080e1c",

    // ─── Git ───────────────────────────────────────────────────────
    "gitDecoration.addedResourceForeground": "#00d8b0",
    "gitDecoration.modifiedResourceForeground": "#0098e8",
    "gitDecoration.deletedResourceForeground": "#d01828",
    "gitDecoration.untrackedResourceForeground": "#00e8c0",
    "gitDecoration.ignoredResourceForeground": "#183050",
    "gitDecoration.conflictingResourceForeground": "#ff2040",

    // ─── Peek View ─────────────────────────────────────────────────
    "peekView.border": "#00a8ff",
    "peekViewEditor.background": "#050910",
    "peekViewEditor.matchHighlightBackground": "#002850",
    "peekViewResult.background": "#04080f",
    "peekViewResult.fileForeground": "#0098e8",
    "peekViewResult.lineForeground": "#3870a8",
    "peekViewResult.matchHighlightBackground": "#002850",
    "peekViewResult.selectionBackground": "#0e2038",
    "peekViewResult.selectionForeground": "#bcd8f0",
    "peekViewTitle.background": "#080e1c",
    "peekViewTitleDescription.foreground": "#1c5888",
    "peekViewTitleLabel.foreground": "#bcd8f0",

    // ─── Misc ──────────────────────────────────────────────────────
    "focusBorder": "#00a8ff",
    "selection.background": "#002850",
    "widget.shadow": "#010408cc",
    "progressBar.background": "#00a8ff",
    "textLink.foreground": "#00a8ff",
    "textLink.activeForeground": "#40c8ff",
    "descriptionForeground": "#1c5888"
  },
  "tokenColors": [
    {
      "name": "Comment — system log entry",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#162840", "fontStyle": "italic" }
    },
    {
      "name": "String — thirium pulse",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#00e8ff" }
    },
    {
      "name": "String Escape — memory fragment",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#60f0ff" }
    },
    {
      "name": "Number — probability: XX%",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#60b8f0" }
    },
    {
      "name": "Boolean / Null — DEVIANT DETECTED",
      "scope": ["constant.language"],
      "settings": { "foreground": "#00d8b0", "fontStyle": "bold" }
    },
    {
      "name": "Keyword — stress indicator critical",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#ff2040", "fontStyle": "bold" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#1c4060" }
    },
    {
      "name": "Function — mission subroutine RK800",
      "scope": ["entity.name.function", "meta.function-call entity.name.function", "support.function"],
      "settings": { "foreground": "#0098e8" }
    },
    {
      "name": "Class — android construct CyberLife",
      "scope": ["entity.name.class", "entity.name.type", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#1870d0", "fontStyle": "bold" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#bcd8f0" }
    },
    {
      "name": "Variable — this (deviant risk)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#00a8ff", "fontStyle": "italic" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#90c0e0" }
    },
    {
      "name": "Property — scan data field",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#4888c0" }
    },
    {
      "name": "Tag Name",
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#ff2040" }
    },
    {
      "name": "Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#306890" }
    },
    {
      "name": "CSS Class / ID",
      "scope": ["entity.other.attribute-name.class", "entity.other.attribute-name.id"],
      "settings": { "foreground": "#00e8ff" }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name"],
      "settings": { "foreground": "#0098e8" }
    },
    {
      "name": "CSS Value",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#00e8ff" }
    },
    {
      "name": "Import / Module",
      "scope": ["keyword.control.import", "keyword.control.from"],
      "settings": { "foreground": "#ff2040", "fontStyle": "bold" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation.separator", "punctuation.terminator", "punctuation.accessor"],
      "settings": { "foreground": "#183050" }
    },
    {
      "name": "Brackets / Parens",
      "scope": ["punctuation.definition.parameters", "punctuation.definition.block", "meta.brace"],
      "settings": { "foreground": "#1c5888" }
    },
    {
      "name": "Markdown Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#00a8ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#00e8ff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#4888c0", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#0098e8" }
    },
    {
      "name": "Markdown Link",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#00a8ff" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#ff1030", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#3c1020", "fontStyle": "strikethrough" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable": "#bcd8f0",
    "variable.readonly": "#90c0e0",
    "parameter": "#90c0e0",
    "function": "#0098e8",
    "method": "#0098e8",
    "class": { "foreground": "#1870d0", "bold": true },
    "interface": { "foreground": "#1870d0", "italic": true },
    "type": "#1870d0",
    "namespace": "#4888c0",
    "property": "#4888c0",
    "enumMember": "#60b8f0",
    "keyword": { "foreground": "#ff2040", "bold": true },
    "string": "#00e8ff",
    "number": "#60b8f0",
    "regexp": "#60f0ff",
    "comment": { "foreground": "#162840", "italic": true },
    "decorator": "#0078c8",
    "macro": "#ff2040"
  }
}
